FOREX_AGENT_BROKER_PROFILE=oanda_practice
FOREX_AGENT_API_KEY=replace_with_your_oanda_token
FOREX_AGENT_ACCOUNT_ID=replace_with_your_oanda_account_id
FOREX_AGENT_REQUEST_TIMEOUT_SECONDS=30
FOREX_AGENT_VERIFY_SSL=true

# MT5 / TMS OANDA example
# FOREX_AGENT_BROKER_PROFILE=tms_oanda_mt5
# FOREX_AGENT_MT5_LOGIN=62398938
# FOREX_AGENT_MT5_PASSWORD=replace_with_your_mt5_password
# FOREX_AGENT_MT5_SERVER=OANDATMS-MT5
# FOREX_AGENT_MT5_TERMINAL_PATH=C:/Program Files/TMS OANDA MetaTrader 5/terminal64.exe
# FOREX_AGENT_MT5_RELAY_URL=http://WINDOWS_HOST:8765
# FOREX_AGENT_MT5_RELAY_TOKEN=replace_with_shared_relay_token

# MT5 demo runner example on Windows
# Use broker+live here because orders are sent to a demo MT5 account, not simulated locally.
# FOREX_AGENT_BROKER_PROFILE=tms_oanda_mt5
# FOREX_AGENT_MT5_LOGIN=replace_with_your_demo_login
# FOREX_AGENT_MT5_PASSWORD=replace_with_your_demo_password
# FOREX_AGENT_MT5_SERVER=replace_with_your_demo_server
# FOREX_AGENT_MT5_TERMINAL_PATH=C:/Program Files/TMS OANDA MetaTrader 5/terminal64.exe
# FOREX_AGENT_RUNNER_SOURCE_MODE=broker
# FOREX_AGENT_RUNNER_EXECUTION_MODE=live
# FOREX_AGENT_RUNNER_ENABLE_LIVE_EXECUTION=true
# FOREX_AGENT_RUNNER_INSTRUMENT=DE30.pro
# FOREX_AGENT_RUNNER_GRANULARITY=H1
# FOREX_AGENT_RUNNER_PERIODS=120
# FOREX_AGENT_RUNNER_ORDER_VOLUME=0.01
# FOREX_AGENT_RUNNER_POLL_INTERVAL_SECONDS=300
# FOREX_AGENT_RUNNER_RUN_ONCE=false

